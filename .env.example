# Pooled connection for app runtime (use the -pooler endpoint from Neon)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
# Direct connection for Prisma CLI migrations
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Liveblocks (whiteboard real-time collaboration)
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=

# Optional: user backup sheet webhook (Google Apps Script Web App URL)
GOOGLE_SHEETS_WEBHOOK_URL=""
