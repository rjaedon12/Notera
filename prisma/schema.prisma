// Koda — Prisma schema for PostgreSQL (Neon serverless)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum StudyMode {
  FLASHCARD
  LEARN
  TEST
  MATCH
  TIMED
}

enum CardStatus {
  NEW
  LEARNING
  MASTERED
}

enum GroupRole {
  OWNER
  MEMBER
}

// ─── Auth (NextAuth v5 Prisma Adapter) ───────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  image             String?
  password          String?   // nullable — OAuth users won't have one
  emailVerified     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  streak            Int       @default(0)
  lastStudied       DateTime?
  role              String    @default("USER") // USER | ADMIN
  resetToken        String?
  resetTokenExpiry  DateTime?

  isBanned         Boolean   @default(false)

  // Relations
  sets             FlashcardSet[]
  progress         StudyProgress[]
  cardProgress     CardProgress[]
  groupMemberships GroupMember[]
  sessions         Session[]
  accounts         Account[]
  ownedGroups      Group[]
  resources        Resource[]
  questionBanks    QuestionBank[]
  quizAttempts     QuizAttempt[]
}

// ─── Flashcards ──────────────────────────────────────────

model FlashcardSet {
  id          String   @id @default(cuid())
  title       String
  description String?
  isPublic    Boolean  @default(false)
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cards     Flashcard[]
  progress  StudyProgress[]
  groupSets GroupSet[]
}

model Flashcard {
  id         String @id @default(cuid())
  term       String
  definition String
  order      Int

  setId String
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  cardProgress CardProgress[]
}

// ─── Study Progress ──────────────────────────────────────

model StudyProgress {
  id            String    @id @default(cuid())
  lastStudied   DateTime  @default(now())
  masteredCount Int       @default(0)
  totalCards    Int       @default(0)
  mode          StudyMode
  score         Float?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  setId String
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([userId, setId, mode])
}

model CardProgress {
  id             String     @id @default(cuid())
  status         CardStatus @default(NEW)
  correctCount   Int        @default(0)
  incorrectCount Int        @default(0)
  lastSeen       DateTime   @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  flashcardId String
  flashcard   Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

// ─── Groups ──────────────────────────────────────────────

model Group {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  members GroupMember[]
  sets    GroupSet[]
}

model GroupMember {
  userId   String
  groupId  String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model GroupSet {
  groupId String
  setId   String

  group Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@id([groupId, setId])
}

// ─── Resources / Timeline ────────────────────────────────

model Resource {
  id         String   @id @default(cuid())
  title      String
  type       String   // TIMELINE, DOCUMENT, etc.
  content    String?
  visibility String   @default("PRIVATE") // PRIVATE, PUBLIC, GROUP
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  timelineEvents TimelineEvent[]
  timelineArrows TimelineArrow[]
}

model TimelineEvent {
  id        String  @id @default(cuid())
  dateLabel String
  title     String
  body      String?
  sortOrder Int     @default(0)
  posX      Float   @default(0)
  posY      Float   @default(0)

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  arrowsFrom TimelineArrow[] @relation("ArrowFrom")
  arrowsTo   TimelineArrow[] @relation("ArrowTo")
}

model TimelineArrow {
  id    String  @id @default(cuid())
  label String?

  fromEventId String
  fromEvent   TimelineEvent @relation("ArrowFrom", fields: [fromEventId], references: [id], onDelete: Cascade)

  toEventId String
  toEvent   TimelineEvent @relation("ArrowTo", fields: [toEventId], references: [id], onDelete: Cascade)

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

// ─── Quizzes ─────────────────────────────────────────────

model QuestionBank {
  id          String   @id @default(cuid())
  title       String
  subject     String
  description String?
  imageUrl    String?
  isPublic    Boolean  @default(false)
  isPremade   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id          String  @id @default(cuid())
  prompt      String
  imageUrl    String?
  passage     String?
  explanation String
  orderIndex  Int     @default(0)

  bankId String
  bank   QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  choices Choice[]
  answers AttemptAnswer[]
}

model Choice {
  id         String  @id @default(cuid())
  text       String
  isCorrect  Boolean @default(false)
  orderIndex Int     @default(0)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answers AttemptAnswer[]
}

model QuizAttempt {
  id          String    @id @default(cuid())
  score       Float?
  completedAt DateTime?
  startedAt   DateTime  @default(now())

  bankId String
  bank   QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers AttemptAnswer[]
}

model AttemptAnswer {
  id        String  @id @default(cuid())
  isCorrect Boolean

  attemptId String
  attempt   QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  choiceId String
  choice   Choice @relation(fields: [choiceId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}
