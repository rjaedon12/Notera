// Koda — Prisma schema for PostgreSQL (Neon serverless)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum StudyMode {
  FLASHCARD
  LEARN
  TEST
  MATCH
  TIMED
}

enum CardStatus {
  NEW
  LEARNING
  MASTERED
}

enum GroupRole {
  OWNER
  MEMBER
}

// ─── Auth (NextAuth v5 Prisma Adapter) ───────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  image             String?
  password          String?   // nullable — OAuth users won't have one
  emailVerified     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  streak            Int       @default(0)
  lastStudied       DateTime?
  role              String    @default("USER") // USER | ADMIN
  resetToken        String?
  resetTokenExpiry  DateTime?

  // Relations
  sets             FlashcardSet[]
  progress         StudyProgress[]
  cardProgress     CardProgress[]
  groupMemberships GroupMember[]
  sessions         Session[]
  accounts         Account[]
  ownedGroups      Group[]
}

// ─── Flashcards ──────────────────────────────────────────

model FlashcardSet {
  id          String   @id @default(cuid())
  title       String
  description String?
  isPublic    Boolean  @default(false)
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cards     Flashcard[]
  progress  StudyProgress[]
  groupSets GroupSet[]
}

model Flashcard {
  id         String @id @default(cuid())
  term       String
  definition String
  order      Int

  setId String
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  cardProgress CardProgress[]
}

// ─── Study Progress ──────────────────────────────────────

model StudyProgress {
  id            String    @id @default(cuid())
  lastStudied   DateTime  @default(now())
  masteredCount Int       @default(0)
  totalCards    Int       @default(0)
  mode          StudyMode
  score         Float?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  setId String
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([userId, setId, mode])
}

model CardProgress {
  id             String     @id @default(cuid())
  status         CardStatus @default(NEW)
  correctCount   Int        @default(0)
  incorrectCount Int        @default(0)
  lastSeen       DateTime   @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  flashcardId String
  flashcard   Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

// ─── Groups ──────────────────────────────────────────────

model Group {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  members GroupMember[]
  sets    GroupSet[]
}

model GroupMember {
  userId   String
  groupId  String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model GroupSet {
  groupId String
  setId   String

  group Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@id([groupId, setId])
}
