// Notera — Prisma schema for PostgreSQL (Neon serverless)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum StudyMode {
  FLASHCARD
  LEARN
  TEST
  MATCH
  TIMED
}

enum CardStatus {
  NEW
  LEARNING
  MASTERED
}

enum GroupRole {
  OWNER
  MEMBER
}

enum NotificationType {
  GROUP_INVITE
  SET_SHARED
  ACHIEVEMENT
  STUDY_REMINDER
  COMMENT
  SYSTEM
}

// ─── Auth (NextAuth v5 Prisma Adapter) ───────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  image             String?
  password          String?   // nullable — OAuth users won't have one
  emailVerified     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  streak            Int       @default(0)
  longestStreak     Int       @default(0)
  lastStudied       DateTime?
  role              String    @default("USER") // USER | TEACHER | ADMIN
  resetToken        String?
  resetTokenExpiry  DateTime?

  isBanned         Boolean   @default(false)

  // Relations
  sets             FlashcardSet[]
  progress         StudyProgress[]
  cardProgress     CardProgress[]
  groupMemberships GroupMember[]
  sessions         Session[]
  accounts         Account[]
  ownedGroups      Group[]
  resources        Resource[]
  questionBanks    QuestionBank[]
  quizAttempts     QuizAttempt[]
  starredSets      StarredSet[]
  savedSets        SavedSet[]
  starredCards     StarredCard[]
  folders          Folder[]
  comments         Comment[]
  ratings          Rating[]
  achievements     UserAchievement[]
  notifications    Notification[]
  dbqEssays        DBQEssay[]
  studySessions    StudySession[]
  sightreadingAttempts SightreadingAttempt[]
  announcements    Announcement[]       @relation("AnnouncementAuthor")
  dismissedAnnouncements AnnouncementDismissal[]
  notePages        NotePage[]
  forumPosts       ForumPost[]
  forumReplies     ForumReply[]
  forumReactions   ForumReaction[]
  whiteboardBoards WhiteboardBoard[] @relation("WhiteboardOwner")
  whiteboardMemberships WhiteboardMember[]
  fsrsProgress  UserFlashcardProgress[]
}

// ─── Flashcards ──────────────────────────────────────────

model FlashcardSet {
  id          String   @id @default(cuid())
  title       String
  description String?
  isPublic    Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cards     Flashcard[]
  progress  StudyProgress[]
  groupSets GroupSet[]
  starredBy StarredSet[]
  savedBy   SavedSet[]
  comments  Comment[]
  ratings   Rating[]
  folderSets FolderSet[]
}

model Flashcard {
  id         String @id @default(cuid())
  term       String
  definition String
  order      Int

  setId String
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  cardProgress  CardProgress[]
  starredBy     StarredCard[]
  fsrsProgress  UserFlashcardProgress[]
}

// ─── Study Progress ──────────────────────────────────────

model StudyProgress {
  id            String    @id @default(cuid())
  lastStudied   DateTime  @default(now())
  masteredCount Int       @default(0)
  totalCards    Int       @default(0)
  mode          StudyMode
  score         Float?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  setId String
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([userId, setId, mode])
}

model CardProgress {
  id             String     @id @default(cuid())
  status         CardStatus @default(NEW)
  correctCount   Int        @default(0)
  incorrectCount Int        @default(0)
  lastSeen       DateTime   @default(now())

  // SM-2 spaced repetition fields
  easeFactor     Float      @default(2.5)
  interval       Int        @default(0)    // days until next review
  nextReviewAt   DateTime?                 // when this card is due

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  flashcardId String
  flashcard   Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

// ─── FSRS Spaced Repetition Progress ─────────────────────

model UserFlashcardProgress {
  id            String    @id @default(cuid())
  userId        String
  flashcardId   String

  // FSRS fields
  due           DateTime  @default(now())
  stability     Float     @default(0)
  difficulty    Float     @default(0)
  elapsedDays   Int       @default(0)
  scheduledDays Int       @default(0)
  reps          Int       @default(0)
  lapses        Int       @default(0)
  state         Int       @default(0) // 0=New, 1=Learning, 2=Review, 3=Relearning
  lastReview    DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
  @@index([userId, due])
}

// ─── Groups ──────────────────────────────────────────────

model Group {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  members GroupMember[]
  sets    GroupSet[]
  notePages NotePage[]
}

model GroupMember {
  userId   String
  groupId  String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model GroupSet {
  groupId String
  setId   String

  group Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@id([groupId, setId])
}

// ─── Resources / Timeline ────────────────────────────────

model Resource {
  id         String   @id @default(cuid())
  title      String
  type       String   // TIMELINE, DOCUMENT, etc.
  content    String?
  visibility String   @default("PRIVATE") // PRIVATE, PUBLIC, GROUP
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  timelineEvents TimelineEvent[]
  timelineArrows TimelineArrow[]
}

model TimelineEvent {
  id        String  @id @default(cuid())
  dateLabel String
  title     String
  body      String?
  sortOrder Int     @default(0)
  posX      Float   @default(0)
  posY      Float   @default(0)

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  arrowsFrom TimelineArrow[] @relation("ArrowFrom")
  arrowsTo   TimelineArrow[] @relation("ArrowTo")
}

model TimelineArrow {
  id    String  @id @default(cuid())
  label String?

  fromEventId String
  fromEvent   TimelineEvent @relation("ArrowFrom", fields: [fromEventId], references: [id], onDelete: Cascade)

  toEventId String
  toEvent   TimelineEvent @relation("ArrowTo", fields: [toEventId], references: [id], onDelete: Cascade)

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

// ─── Quizzes ─────────────────────────────────────────────

model QuestionBank {
  id          String   @id @default(cuid())
  title       String
  subject     String
  description String?
  imageUrl    String?
  isPublic    Boolean  @default(false)
  isPremade   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id          String  @id @default(cuid())
  prompt      String
  imageUrl    String?
  passage     String?
  explanation String
  orderIndex  Int     @default(0)

  bankId String
  bank   QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  choices Choice[]
  answers AttemptAnswer[]
}

model Choice {
  id         String  @id @default(cuid())
  text       String
  isCorrect  Boolean @default(false)
  orderIndex Int     @default(0)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answers AttemptAnswer[]
}

model QuizAttempt {
  id          String    @id @default(cuid())
  score       Float?
  completedAt DateTime?
  startedAt   DateTime  @default(now())

  bankId String
  bank   QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers AttemptAnswer[]
}

model AttemptAnswer {
  id        String  @id @default(cuid())
  isCorrect Boolean

  attemptId String
  attempt   QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  choiceId String
  choice   Choice @relation(fields: [choiceId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

// ─── Starred Sets ────────────────────────────────────────

model StarredSet {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  setId String
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([userId, setId])
}

// ─── Saved Sets ──────────────────────────────────────────

model SavedSet {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  setId String
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([userId, setId])
}

// ─── Starred Cards ───────────────────────────────────────

model StarredCard {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  flashcardId String
  flashcard   Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

// ─── Folders ─────────────────────────────────────────────

model Folder {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  sets FolderSet[]
}

model FolderSet {
  folderId String
  setId    String

  folder Folder       @relation(fields: [folderId], references: [id], onDelete: Cascade)
  set    FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@id([folderId, setId])
}

// ─── Comments & Ratings ──────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  setId String
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)
}

model Rating {
  id        String   @id @default(cuid())
  score     Int      // 1-5 stars
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  setId String
  set   FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([userId, setId])
}

// ─── Achievements ────────────────────────────────────────

model UserAchievement {
  id         String   @id @default(cuid())
  achieveKey String   // e.g. "first_set", "streak_7", "cards_100"
  unlockedAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achieveKey])
}

// ─── DBQ (Document-Based Questions) ──────────────────────

model DBQPrompt {
  id        String   @id @default(cuid())
  title     String
  question  String
  subject   String
  era       String
  createdAt DateTime @default(now())

  documents DBQDocument[]
  essays    DBQEssay[]
}

model DBQDocument {
  id         String  @id @default(cuid())
  docNumber  Int
  title      String
  source     String
  content    String
  imageUrl   String?
  imageAlt   String?
  orderIndex Int     @default(0)

  promptId String
  prompt   DBQPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
}

model DBQEssay {
  id          String    @id @default(cuid())
  content     String
  highlights  String?   // JSON array of highlight data
  wordCount   Int       @default(0)
  submittedAt DateTime  @default(now())

  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  promptId String
  prompt   DBQPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
}

// ─── Notifications ───────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Study Sessions (real session tracking) ──────────────

model StudySession {
  id        String   @id @default(cuid())
  type      String   // FLASHCARD, QUIZ, MATCH, TIMED, SIGHTREADING
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Sightreading ────────────────────────────────────────

model SightreadingAttempt {
  id        String   @id @default(cuid())
  clef      String   // TREBLE, BASS, ALTO
  level     String   // e.g. "naturals", "sharps", "flats", "all"
  correct   Int      @default(0)
  total     Int      @default(0)
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Announcements (broadcast from admin) ────────────────

model Announcement {
  id          String    @id @default(cuid())
  title       String
  message     String
  type        String    @default("INFO") // INFO, WARNING, UPDATE, MAINTENANCE
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  createdById String
  createdBy   User @relation("AnnouncementAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  dismissals  AnnouncementDismissal[]
}

model AnnouncementDismissal {
  userId         String
  announcementId String
  dismissedAt    DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@id([userId, announcementId])
}

// ─── Forum ───────────────────────────────────────────────

model ForumPost {
  id        String   @id @default(cuid())
  title     String
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  replies   ForumReply[]
  reactions ForumReaction[] @relation("PostReactions")

  @@index([createdAt])
  @@index([userId])
}

model ForumReply {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String
  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  parentReplyId String?
  parentReply   ForumReply?  @relation("ReplyThread", fields: [parentReplyId], references: [id], onDelete: SetNull)
  childReplies  ForumReply[] @relation("ReplyThread")

  reactions ForumReaction[] @relation("ReplyReactions")

  @@index([postId, createdAt])
  @@index([userId])
  @@index([parentReplyId])
}

model ForumReaction {
  id        String   @id @default(cuid())
  type      String   // LIKE or DISLIKE
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId  String?
  post    ForumPost? @relation("PostReactions", fields: [postId], references: [id], onDelete: Cascade)

  replyId String?
  reply   ForumReply? @relation("ReplyReactions", fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type])
  @@unique([userId, replyId, type])
  @@index([postId])
  @@index([replyId])
}

// ─── Notes (Notion-style pages) ──────────────────────────

model NotePage {
  id          String      @id @default(cuid())
  title       String      @default("Untitled")
  icon        String?     // emoji or URL
  coverImage  String?     // URL to cover photo
  content     Json?       // Tiptap ProseMirror JSON document
  isFullWidth Boolean     @default(false)
  isFavorite  Boolean     @default(false)
  isArchived  Boolean     @default(false)
  isPublic    Boolean     @default(false)

  // Hierarchy
  parentId    String?
  parent      NotePage?   @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    NotePage[]  @relation("PageHierarchy")
  sortOrder   Int         @default(0)

  // Ownership
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional group attachment
  groupId     String?
  group       Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
  @@index([parentId])
  @@index([groupId])
}

// ─── Whiteboard ──────────────────────────────────────────

enum WhiteboardRole {
  OWNER
  EDITOR
  VIEWER
}

model WhiteboardBoard {
  id          String   @id @default(cuid())
  title       String   @default("Untitled Board")
  thumbnail   String?  // base64 data URL or storage URL
  elements    Json     @default("[]") // serialised WhiteboardElement[]
  background  String   @default("plain") // plain | dots | grid | lined
  bgColor     String   @default("#ffffff")
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User @relation("WhiteboardOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members    WhiteboardMember[]
  shareLinks WhiteboardShareLink[]

  @@index([ownerId])
  @@index([updatedAt])
}

model WhiteboardMember {
  boardId  String
  userId   String
  role     WhiteboardRole @default(EDITOR)
  joinedAt DateTime       @default(now())

  board WhiteboardBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([boardId, userId])
  @@index([userId])
}

model WhiteboardShareLink {
  id         String          @id @default(cuid())
  token      String          @unique @default(cuid())
  permission WhiteboardRole  @default(VIEWER)
  expiresAt  DateTime?
  createdAt  DateTime        @default(now())

  boardId String
  board   WhiteboardBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([boardId])
}
